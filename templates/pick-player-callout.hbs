<form class="sr-pick-player-callout-form">
  <div class="form-group">
    <label>{{localize "simple-requests.pickPlayerCallout.playerLabel"}}</label>
    <select name="userId">
      {{#each players}}
      <option value="{{id}}">{{name}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>{{localize "simple-requests.pickPlayerCallout.calloutType"}}</label>
    <div class="sr-callout-mode">
      <label class="sr-callout-mode-opt"><input type="radio" name="calloutMode" value="up" checked> {{localize "simple-requests.pickPlayerCallout.modeUp"}}</label>
      <label class="sr-callout-mode-opt"><input type="radio" name="calloutMode" value="dice"> {{localize "simple-requests.pickPlayerCallout.modeDice"}}</label>
    </div>
  </div>
  <div class="form-group sr-callout-dice-row" style="display:none">
    <label>{{localize "simple-requests.pickPlayerCallout.pickDie"}}</label>
    <div class="sr-callout-dice-buttons">
      {{#each dieFaces}}
      <button type="button" class="sr-callout-die" data-faces="{{this}}">d{{this}}</button>
      {{/each}}
    </div>
    <input type="hidden" name="dieFaces" value="">
  </div>
  <div class="form-group sr-callout-count-row" style="display:none">
    <label>{{localize "simple-requests.pickPlayerCallout.countLabel"}}</label>
    <select name="diceCount">
      {{#each diceCounts}}
      <option value="{{this}}">{{this}}</option>
      {{/each}}
    </select>
  </div>
</form>
