<div class="sr-pick-player-callout">
  <div class="form-group">
    <label>{{localize "simple-requests.pickPlayerCallout.playerLabel"}}</label>
    <select name="userId">
      {{#each players}}
      <option value="{{id}}">{{name}}</option>
      {{/each}}
    </select>
  </div>
  <section class="sr-callout-section sr-callout-section-message">
    <h4 class="sr-callout-section-title">{{localize "simple-requests.pickPlayerCallout.messageSection"}}</h4>
    <form class="sr-callout-message-form">
      <div class="form-group">
        <label>{{localize "simple-requests.pickPlayerCallout.messageLabel"}}</label>
        <input type="text" name="calloutMessage" value="{{messageDefault}}" maxlength="120" autocomplete="off">
        </div>
      <button type="submit" class="sr-callout-send-message">{{localize
        "simple-requests.pickPlayerCallout.sendMessageButton"}}</button>
      </form>
      </section>
      <section class="sr-callout-section sr-callout-section-dice">
        <h4 class="sr-callout-section-title">{{localize "simple-requests.pickPlayerCallout.rollSection"}}</h4>
        <form class="sr-callout-dice-form">
          <div class="form-group">
            <label>{{localize "simple-requests.pickPlayerCallout.countLabel"}}</label>
            <select name="diceCount">
              {{#each diceCounts}}
              <option value="{{this}}">{{this}}</option>
              {{/each}}
            </select>
          </div>
      <div class="form-group">
        <label>{{localize "simple-requests.pickPlayerCallout.pickDie"}}</label>
        <div class="sr-callout-dice-buttons">
          {{#each dieFaces}}
          <button type="submit" name="dieFaces" value="{{this}}" class="sr-callout-die">d{{this}}</button>
          {{/each}}
          </div>
      </div>
      </form>
  </section>
  </div>
