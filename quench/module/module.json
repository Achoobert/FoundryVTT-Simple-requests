{
  "id": "simple-requests-tests",
  "title": "Simple Requests Tests",
  "description": "Test suite to run Quench tests in game on the Simple Requests module",
  "authors": [
    {
      "name": "Miskatonic Investigative Society"
    },
    {
      "name": "kwitczak"
    }
  ],
  "version": "0.0.1",
  "compatibility": {
    "minimum": "13",
    "verified": "14"
  },
  "relationships": {
    "requires": [
      {
        "id": "quench",
        "type": "module",
        "reason": "Process Tests powered by Mocha."
      },
      {
